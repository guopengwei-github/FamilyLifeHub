# Database
# 可选：直接指定数据库路径（优先级最高）
# DATABASE_URL=sqlite:///./family_life_hub.db
# 可选：指定数据目录（默认为 %APPDATA%\family_life_hub 或 ~/.local/share/family_life_hub）
# DATA_DIR=C:\Users\YourName\AppData\Roaming\family_life_hub

# API Security
API_KEY=your-secret-api-key-change-this-in-production

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Application
APP_NAME=FamilyLifeHub
DEBUG=True
